{% extends 'base.html.twig' %}

{% block title %}Welcome to MyShop{% endblock %}

{% block content %}
    <section class="hero">
        <h2>Top Deals of the Week</h2>
        <p>Check out the latest products and best deals!</p>
    </section>

    <section class="products-grid">
        {% for product in products %}
            <div class="product-card">
                <img src="{{ product.image }}" alt="{{ product.name }}">
                <h3>{{ product.name }}</h3>
                <p>${{ product.price }}</p>
                <a href="{{ path('product_detail', {id: product.id}) }}" class="btn">View Details</a>
            </div>
        {% endfor %}
    </section>
{% endblock %}
